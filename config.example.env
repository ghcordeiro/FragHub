# FragHub — Client Configuration Template
# =========================================
# Copy to clients/<client-name>.env, fill in, then deploy:
#   bash scripts/installer/install.sh --config clients/<client-name>.env
#
# Permissions: chmod 600 clients/<client-name>.env
# Never commit this file with real secrets.

# ---------------------------------------------------------------------------
# REQUIRED
# ---------------------------------------------------------------------------

# Identifier for this server (used in logs and Discord notifications)
FRAGHUB_SERVER_HOSTNAME="meu-servidor-cs2"

# Steam Web API key — https://steamcommunity.com/dev/apikey
FRAGHUB_STEAM_WEB_API_KEY=""

# Initial admin account (created in the database after install)
FRAGHUB_ADMIN_EMAIL=""
FRAGHUB_ADMIN_PASSWORD=""   # min 8 chars, must have uppercase + lowercase + digit

# ---------------------------------------------------------------------------
# OPTIONAL — passwords (auto-generated if blank)
# ---------------------------------------------------------------------------

# Leave blank to auto-generate a secure password
FRAGHUB_DB_PASSWORD=""
FRAGHUB_RCON_PASSWORD=""

# ---------------------------------------------------------------------------
# OPTIONAL — public access
# ---------------------------------------------------------------------------

# Public domain (e.g. play.example.com). Leave blank for localhost/IP-only.
FRAGHUB_DOMAIN=""

# Discord webhook URL for match notifications and CS2 update alerts
# https://discord.com/api/webhooks/...
FRAGHUB_DISCORD_WEBHOOK=""

# ---------------------------------------------------------------------------
# OPTIONAL — Google OAuth (both required together or both blank)
# ---------------------------------------------------------------------------

FRAGHUB_GOOGLE_CLIENT_ID=""
FRAGHUB_GOOGLE_CLIENT_SECRET=""

# ---------------------------------------------------------------------------
# OPTIONAL — game stack
# ---------------------------------------------------------------------------

# Set to 1 to install CS2/CS:GO game servers (requires more disk + RAM)
FRAGHUB_ENABLE_GAME_STACK=0

# CS2 update monitor interval in minutes (default: 2)
# FRAGHUB_CS2_MONITOR_INTERVAL=2

# ---------------------------------------------------------------------------
# ADVANCED — paths and ports (safe to leave as defaults)
# ---------------------------------------------------------------------------

# FRAGHUB_API_PORT=3001
# FRAGHUB_SYSADMIN_PORT=8081
# FRAGHUB_SYSADMIN_PUBLIC_PORT=8080
# FRAGHUB_API_DIR=/opt/fraghub/api
# FRAGHUB_PORTAL_DIR=/opt/fraghub/portal
# FRAGHUB_SYSADMIN_DIR=/opt/fraghub/sysadmin
# FRAGHUB_LINUXGSM_DIR=${HOME}/fraghub/linuxgsm
# FRAGHUB_CS2_INSTANCE=cs2server
